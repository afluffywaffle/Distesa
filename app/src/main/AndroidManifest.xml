<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="Avosetta"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustNothing">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" />
                <data android:scheme="https" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="Settings"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <activity
            android:name=".LayoutActivity"
            android:exported="false"
            android:label="Layout"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <activity
            android:name=".RenderingActivity"
            android:exported="false"
            android:label="Rendering"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <activity
            android:name=".SupernoteActivity"
            android:exported="false"
            android:label="Supernote"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <activity
            android:name=".AccessibilityActivity"
            android:exported="false"
            android:label="Accessibility"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <activity
            android:name=".HistoryActivity"
            android:exported="false"
            android:label="History"
            android:configChanges="orientation|screenSize|keyboardHidden" />
    </application>
</manifest>
