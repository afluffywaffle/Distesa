{
    "manifest_version": 2,
    "name": "Achroma E-Ink",
    "description": "Tap-to-flip quantized page turning tuned for e-ink (Supernote).",
    "version": "1.0",

    "browser_specific_settings": {
        "gecko": {
            "id": "eink@achroma"
        }
    },

    "background": {
        "scripts": [ "background.js" ]
    },

    "content_scripts": [
        {
            "js": [ "content.js" ],
            "matches": [ "<all_urls>" ],
            "run_at": "document_idle"
        },
        {
            "js": [ "images.js" ],
            "matches": [ "<all_urls>" ],
            "run_at": "document_start"
        }
    ],

    "permissions": [ "nativeMessaging", "geckoViewAddons", "storage" ]
}
