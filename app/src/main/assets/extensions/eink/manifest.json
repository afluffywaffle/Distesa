{
    "manifest_version": 2,
    "name": "Distesa E-Ink",
    "description": "Tap-to-flip quantized page turning tuned for e-ink (Supernote).",
    "version": "1.0",

    "browser_specific_settings": {
        "gecko": {
            "id": "eink@distesa"
        }
    },

    "background": {
        "scripts": [ "background.js" ]
    },

    "content_scripts": [
        {
            "js": [ "images.js" ],
            "matches": [ "<all_urls>" ],
            "run_at": "document_start"
        }
    ],

    "permissions": [
        "nativeMessaging",
        "geckoViewAddons",
        "storage",
        "webRequest",
        "webRequestBlocking",
        "webNavigation",
        "<all_urls>"
    ]
}
